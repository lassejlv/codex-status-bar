{
  "hooks": {
    "SessionStart": [
      { "matcher": "startup|resume|clear|compact", "hooks": [{ "type": "command", "command": "'/Applications/CodexStatusBar.app/Contents/Resources/CodexStatusHook' SessionStart # codex-status-bar-hook", "timeout": 5 }] }
    ],
    "UserPromptSubmit": [
      { "hooks": [{ "type": "command", "command": "'/Applications/CodexStatusBar.app/Contents/Resources/CodexStatusHook' UserPromptSubmit # codex-status-bar-hook", "timeout": 5 }] }
    ],
    "PreToolUse": [
      { "matcher": "*", "hooks": [{ "type": "command", "command": "'/Applications/CodexStatusBar.app/Contents/Resources/CodexStatusHook' PreToolUse # codex-status-bar-hook", "timeout": 5 }] }
    ],
    "PostToolUse": [
      { "matcher": "*", "hooks": [{ "type": "command", "command": "'/Applications/CodexStatusBar.app/Contents/Resources/CodexStatusHook' PostToolUse # codex-status-bar-hook", "timeout": 5 }] }
    ],
    "PermissionRequest": [
      { "matcher": "*", "hooks": [{ "type": "command", "command": "'/Applications/CodexStatusBar.app/Contents/Resources/CodexStatusHook' PermissionRequest # codex-status-bar-hook", "timeout": 5 }] }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "'/Applications/CodexStatusBar.app/Contents/Resources/CodexStatusHook' Stop # codex-status-bar-hook", "timeout": 5 }] }
    ]
  }
}
